# ──────────────────────────────────────────────────────────────────────────────
# Discord Automod Badge Deployer — Configuration Template
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────────────────────────────────────

# Bot token — Discord Developer Portal → Your App → Bot → Reset Token
BOT_TOKEN=your_bot_token_here

# Channel ID where deployment logs will be posted (right-click channel → Copy ID)
LOG_CHANNEL_ID=your_log_channel_id_here

# Your Discord user ID (right-click your profile → Copy ID with Developer Mode on)
CREATOR_ID=your_discord_user_id_here

# ── Deployment timing ─────────────────────────────────────────────────────────
RULE_DELAY=1500
SERVER_DELAY=3000

# ── Target servers ────────────────────────────────────────────────────────────
# STANDARD: 6 rules each
STANDARD_SERVER_IDS=server_id_1,server_id_2,server_id_3

# MANY: 9 rules each (your own active servers)
MANY_SERVER_IDS=server_id_4,server_id_5

# Protected servers the bot will never touch
BLOCKED_SERVER_IDS=
